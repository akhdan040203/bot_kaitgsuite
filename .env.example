TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=
SUPPORT_USERNAME=
DEFAULT_PRICE_PER_ACCOUNT=2000
MIN_KAIT_ACCOUNTS=10
BONUS_MILESTONE_STEP=1000
BONUS_CREDIT_PER_1000=70

# Existing emulator ports used by mumu-psc.py
port1=16512
port2=16448
port3=16416

# PaysafeCard credential used by the PSC worker.
PSC_EMAIL=
PSC_PASS=

# Prioritas kota ExpressVPN untuk order UK. Kota pertama akan dicoba lebih dulu.
VPN_CITIES_UK=UK - London,UK - East London

# PSC: coba buka halaman Payment methods langsung dulu; kalau gagal fallback ke Play Store home.
PSC_DIRECT_PAYMENT_LINK=1
PSC_PAYMENT_DIRECT_TRIES=2
PSC_PAYMENT_DIRECT_WAIT_SEC=10
PSC_PAYMENT_METHODS_URL=https://play.google.com/store/paymentmethods?hl=id&pli=1

# Optional Python command. On Windows this may be python, py, or a full path.
PYTHON_BIN=python
WORKER_POLL_MS=5000

# Optional Order Kuota adapter.
# If ORDERKUOTA_CREATE_URL is empty, bot uses manual mode and admin can run /paid ORDER_ID.
ORDERKUOTA_CREATE_URL=
ORDERKUOTA_STATUS_URL=
ORDERKUOTA_API_TOKEN=
ORDERKUOTA_REF_PATH=data.reference
ORDERKUOTA_QRIS_PATH=data.qris
ORDERKUOTA_QRIS_IMAGE_PATH=data.qr_image
ORDERKUOTA_STATUS_PATH=data.status
