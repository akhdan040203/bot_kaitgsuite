TELEGRAM_BOT_TOKEN=123456:telegram-bot-token
TELEGRAM_ADMIN_IDS=123456789,987654321
SUPPORT_USERNAME=@admin
DEFAULT_PRICE_PER_ACCOUNT=2000
MIN_KAIT_ACCOUNTS=10

# Existing emulator ports used by mumu-psc.py
port1=16512
port2=16448
port3=16416

# PaysafeCard credential used by the PSC worker.
PSC_EMAIL=your-psc-email@example.com
PSC_PASS=your-psc-password

# Optional Python command. On Windows this may be python, py, or a full path.
PYTHON_BIN=python
WORKER_POLL_MS=5000

# Optional Order Kuota adapter.
# If ORDERKUOTA_CREATE_URL is empty, bot uses manual mode and admin can run /paid ORDER_ID.
ORDERKUOTA_CREATE_URL=
ORDERKUOTA_STATUS_URL=
ORDERKUOTA_API_TOKEN=
ORDERKUOTA_REF_PATH=data.reference
ORDERKUOTA_QRIS_PATH=data.qris
ORDERKUOTA_QRIS_IMAGE_PATH=data.qr_image
ORDERKUOTA_STATUS_PATH=data.status
